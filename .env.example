# Porta do servidor
PORT=3001

# ============================================
# CONFIGURAÇÃO DO BANCO DE DADOS (SUPABASE)
# ============================================
#
# Para obter as credenciais do Supabase:
# 1. Acesse https://app.supabase.com
# 2. Selecione seu projeto
# 3. Vá em Settings > Database
# 4. Copie a "Connection string" (URI)
#
# Formato: postgresql://postgres:[SENHA]@db.[PROJETO].supabase.co:5432/postgres
#
DATABASE_URL=postgresql://postgres:SUA_SENHA_SUPABASE@db.SEU_PROJETO.supabase.co:5432/postgres

# Supabase API (opcional - para funcionalidades avançadas)
# Encontre em Settings > API
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_ANON_KEY=eyJ...sua-chave-anon
SUPABASE_SERVICE_KEY=eyJ...sua-chave-service

# Chave secreta para JWT
# IMPORTANTE: Gere uma chave segura em produção
# Para gerar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=sua_chave_secreta_muito_segura_aqui

# Ambiente de execução
NODE_ENV=development

# Configurações de Email (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=seu_email@gmail.com
EMAIL_PASS=sua_senha_de_aplicativo
EMAIL_FROM_NAME=Gestor Consórcios
EMAIL_FROM_EMAIL=seu_email@gmail.com

# URLs do Frontend (para CORS e redirecionamentos)
FRONTEND_URL=http://localhost:3000

# Configurações de Segurança
# Rate Limiting - Máximo de requisições por janela de tempo (15 minutos)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Rate Limiting para Login - Previne brute force (15 minutos)
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
